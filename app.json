{
  "expo": {
    "name": "Product Assessment App",
    "slug": "shoplite",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "myshoplite",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.hamzadar.shoplite"
    },
    "android": {
      "edgeToEdgeEnabled": true,
      "intentFilters": [
        {
          "action": "VIEW",
          "data": [
            {
              "scheme": "myshoplite"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ],
      "package": "com.hamzadar.shoplite"
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-image"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
